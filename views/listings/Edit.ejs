<% layout('/layouts/boilerplate') -%>

<body>
    <div class="edit-container">
    <div class="row"> 
      <div class="col-md-6 offset-md-3">

      <h1 class="text-center">Now you can Edit !!</h1><br><br>
      <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" 
        novalidate class="needs-validation" enctype="multipart/form-data">
          <div class="row ">
            <div class="mb-3 col-md-6">
              <label for="title" class="form-title" >Title:</label>
              <input name="listing[title]" type="text" id="input-b" value="<%=listing.title%>" class="form-control">
            <div class="valid-feedback">Title looks good !! </div>
            </div>
            <div class="mb-3 col-md-6">
               <label for="title" class="form-title" >Category:</label>
              <select id="input-b" class="form-control"  name="listing[category]" required>
                  <option value="">Select category</option>
                  <option value="rooms">rooms</option>
                  <option value="beach">beach</option>
                  <option value="city">city</option>
                  <option value="pools">pools</option>
                  <option value="lakes">lakes</option>

              </select>
              <div class="invalid-feedback">Please select category! </div>

            </div>
            <div class="mb-3 col-md-6">
              <label for="location" class="form-location">Price:</label>
              <input  name="listing[price]" id="input-b" type="number" value="<%=listing.price%>" class="form-control">
            </div>
          </div>  
         <div class="row ">
            <div class="mb-3 col-md-6">
               <label for="location" class="form-location">Location:</label>
               <input  name="listing[location]" id="input-b" type="text" value="<%=listing.location%>" class="form-control">
            </div>
            <div class="mb-3 col-md-6">
               <label for="country" class="form-country">Country:</label>
               <input  name="listing[country]" id="input-b" type="text" value="<%=listing.country%>" class="form-control">
            </div>
         </div>
          <div class="mb-3 col-md-6">
               <label for="image" class="form-image"> Old listing image </label><br>
            <img src="<%= originalImageUrl %>" alt="Listing Image" class="img-fluid">
          </div>
           <div class=" row mb-3 col-md-12">
               <label for="image" class="form-image"> Upload New listing image </label>
               <input  name="listing[image]"  id="input-b" type="file"  class="form-control">
           </div><br>
           <div class=" row mb-3 col-md-12">
                <label for="description" class="form-description">Description:</label>
                <textarea  name="listing[description]" id="input-b" type="text" value="<%=listing.description%>" class="form-control" > </textarea>
                <div class="invalid-feedback">Please enter a short description.</div>
           </div><br><br>
           <div class="d-grid gap-md-5 d-md-flex justify-content-md-center align-items-center">
             <button class="btn btn-primary ">  Edit Listing</button><br><br>
             <a href="/listings/<%= listing._id %>" class="btn btn-secondary float-right">Cancel</a>
             <br><br>
           </div>
          
    </form>
    </div>
    </div>
</body>
