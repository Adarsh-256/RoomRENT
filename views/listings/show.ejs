<% layout('/layouts/boilerplate') -%>
<body>
   <div class="show-container">
     <div class="row mt-4">
      <div class="col-8 offset-3">
           <h1><b> <%= listing.title %></b></h1><br>
      </div>     
      <div class="card col-5 offset-3 show-card" >
            <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image" />
      </div><br>
      <div class="card-body offset-3">
         <p class="card-text">
             <br/> 
               Posted by: <b><%= listing.owner.username || "UnKnown user" %></b> <br/> 
            <%= listing.description %> <br/>
             &#8377; <%= listing.price.toLocaleString('en-IN') %> /night <br/>
             <%= listing.location %> <br/>
             <%= listing.country %>
         </p><br>
      </div>
      <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
       <div class="btns offset-2 ">
            <a href="/listings/<%=listing._id%>/edit" id="show-btn" class="btn btn-primary col-1 offset-2  ">Edit </a><br><br>
         <form method="POST"  action="/listings/<%=listing._id%>?_method=DELETE">
            <button id="show-btn" class="btn btn-secondary offset-2 ">Delete </button>
         </form>
       </div>         
        <%}%>
      </div> 
   </div>
   
   <div class="col-8 offset-3">
      <% if(currUser){%>
      <hr>
         <h4>Leave a Review</h4>
         <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
            <div>
            <fieldset class="starability-slot">
               <legend>rating:</legend>
               <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
               <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
               <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
               <input type="radio" id="first-rate5" name="review[rating]" value="5" />
               <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            </div>
            <br>
            <div>
               <label for="comment" class="form-label">Comments</label>
               <textarea name="review[comment]" id="comment" cols="20" rows="5" class=" form-control" required></textarea>
                <div class="invalid-feedback">
               Please add some comment for Review.
                 </div>
            </div>
            <br>
            <button class="btn btn-primary">Submit Review</button>
         </form>
         <hr>
         <%}%>
         <% if(listing.reviews.length > 0) { %>
         <h4><b>All Reviews<b></h4>
            <div class="row">
               <% for(review of listing.reviews) { %>
              <div class="card col-5 ms-3 md-3">
               <div class="card-body">
                  <h5>Posted:<%= review.author ? review.author.username:"unknown user"%></h5>
                   <p class="starability-result" data-rating="<%= review.rating %>">Rated: <%= review.rating %> stars</p>
                   <p><%= review.comment %> </p> 
                  <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                     <button class="btn btn-danger btn-sm">Delete Review</button>
                  </form>
               </div>
               </div>
             <% } %>
            </div>
         <%}%>
    <div id="map"></div>
   </div>
  
 <% if (listing.geometry && listing.geometry.coordinates) { %>
<script>
document.addEventListener("DOMContentLoaded", function () {
  const lat = Number(<%= listing.geometry.coordinates[1] %>);
  const lng = Number(<%= listing.geometry.coordinates[0] %>);
  console.log(lat, lng);
  const map = L.map('map').setView([lat, lng], 12);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
    attribution: '&copy; OpenStreetMap contributors'
  }).addTo(map);
  L.marker([lat, lng]).addTo(map);
});
</script>
<% } else { %>
<p>📍 Location not available</p>
<% } %>  
  
</body>