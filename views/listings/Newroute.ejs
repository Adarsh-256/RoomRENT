<% layout('/layouts/boilerplate') -%>

<body class="new-container">
    <div class="row"> 
      <div class="col-md-6 offset-md-3">

      <h1 class="text-center">Create New Villa </h1><br><br>
      <form method="POST" action="/listings" novalidate class="row g-3 needs-validation" enctype="multipart/form-data">
          <div class="row ">
            <div class="mb-3 col-md-6">
              <label for="title" class="form-title" >Title:</label>
              <input name="listing[title]" id="input-b" type="text" placeholder=" Enter listing title" class="form-control" required>
              <div class="invalid-feedback">Please enter the title! </div>
            </div>
            <div class="mb-3 col-md-6">
               <label for="title" class="form-title" >Category:</label>
              <select id="input-b" class="form-control" name="listing[category]" required>
                  <option value="">Select category</option>
                  <option value="rooms">rooms</option>
                  <option value="beach">beach</option>
                  <option value="city">city</option>
                  <option value="pools">pools</option>
                  <option value="lakes">lakes</option>
                  <option value="trending">trending</option>
                  
              </select>
              <div class="invalid-feedback">Please select category! </div>

            </div>
            <div class="mb-3 col-md-6">
              <label for="location" class="form-location">Price:</label>
              <input  name="listing[price]"class="form-control" id="input-b" placeholder="Enter Price" required>
              <div class="invalid-feedback">Please enter the Price! </div>
            </div>
          </div>  
         <div class="row ">
            <div class="mb-3 col-md-6">
               <label for="location" class="form-location">Location:</label>
               <input  name="listing[location]" id="input-b" type="text"class="form-control" placeholder="Enter location" required>
              <div class="invalid-feedback">Please enter the location! </div>
            </div>
            <div class="mb-3 col-md-6">
               <label for="country" class="form-country">Country:</label>
               <input  name="listing[country]" id="input-b" type="text" class="form-control" placeholder="Enter country"required>
              <div class="invalid-feedback">Please enter the country name! </div>
            </div>
         </div>
           <div class=" row mb-3 col-md-12">
               <label for="image" class="form-image">Upload listing image:</label>
               <input  name="listing[image]" id="input-b" type="file" class="form-control" placeholder="Upload listing image " required>
              <div class="invalid-feedback">Please upload an image! </div>
        
           </div><br>
           <div class=" row mb-3 col-md-12">
                <label for="description" class="form-description">Description:</label>
                <textarea  name="listing[description]" id="input-b" type="text" class="form-control" placeholder="Enter description"required></textarea>
              <div class="invalid-feedback">Please write short description!</div>

           </div><br><br>
           <div class="d-grid gap-md-5 d-md-flex justify-content-md-center align-items-center">
             <button class="btn btn-primary ">  Create Listing</button><br><br>
             <a href="/listings" class="btn btn-secondary float-right"> Back to Listings</a>
             <br><br>
           </div>
          
    </form>
    </div>
    </div>
</body> 