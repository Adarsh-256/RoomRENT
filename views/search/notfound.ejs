<% layout("/layouts/boilerplate") %>
<br><br>

<div class="container text-center mt-5">
  <h1 class="display-9  fw-bold">😕 No results found</h1>

  <p class="text-muted fs-5 mt-3">
    We couldn't find anything matching
    <span class="fw-semibold">"<%= query %>"</span>
  </p>

  <img 
    src="https://cdni.iconscout.com/illustration/premium/thumb/girl-searching-on-website-using-laptop-illustration-svg-download-png-10018852.png"
    alt="No results"
    style="max-width: 320px"
    class="my-4"
  >

  <p class="text-muted">
    Try searching with different keywords or explore all listings.
  </p>

  <a href="/listings" class="btn btn-primary mt-3">
    🔍 Browse All Listings
  </a>
</div>
<br><br><br>
